#!/usr/bin/env bash
set -euo pipefail

echo -e "\nbuilding blogs.js..."

OUTFILE="blogs.js"
TMPFILE="$(mktemp).js"

write(){ echo "$@" >> "$TMPFILE"; }

load_blog_slug(){ jq -r .meta.blog_slug "$1/blog.json"; }

declare -A dir_for_name
for dir in */*/; do
  [[ -f "${dir}blog.json" ]] || continue
  d=${dir%/}
  blog_slug=$(load_blog_slug "$d")
  dir_for_name[$blog_slug]="$d"
done

IFS=$'\n' sorted_names=($(printf "%s\n" "${!dir_for_name[@]}" | sort))
unset IFS

write "// THIS FILE IS AUTOGENERATED. DO NOT EDIT MANUALLY."
write ""
for name in "${sorted_names[@]}"; do
  dir=${dir_for_name[$name]}
  write "import $name from './$dir/blog.json';"
done

write ""
write "export const blogs = ["
for name in "${sorted_names[@]}"; do
  write "  $name,"
done
write "];"
write ""
write "export default blogs;"

mv "$TMPFILE" "$OUTFILE"
echo "Build succeeded: $OUTFILE"
